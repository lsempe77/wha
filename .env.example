NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database. Use sqlite for dev, postgres:// for prod
DATABASE_URL="file:./dev.db"
# Note: dev uses prisma/schema.prisma (sqlite). Prod uses prisma/schema.prod.prisma (postgresql)
# docker-compose handles this automatically.

# Redis (BullMQ). Use redis:// or rediss:// for prod
REDIS_URL="redis://localhost:6379"

# WhatsApp Cloud API (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_PHONE=
WHATSAPP_API_VERSION=v21.0
# Max messages per minute per number (Meta tier dependent)
WHATSAPP_RATE_LIMIT_PER_MIN=250

# Webhook verification token (set when registering webhook in Meta dashboard)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change_me_in_production
WHATSAPP_APP_SECRET=

# API auth for dashboard/management endpoints
API_KEY=

# JWT for user auth (dashboard login). Use a long random string in prod.
JWT_SECRET=dev_secret_change_me
JWT_EXPIRES_IN=7d
# Default admin created on first run (leave empty to skip seeding admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# CORS allowed origins (comma separated)
CORS_ORIGIN=*
