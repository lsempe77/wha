{
  "name": "whatsapp-broadcaster",
  "version": "1.0.0",
  "description": "Schedule and broadcast WhatsApp messages to contact lists via WhatsApp Cloud API",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "dev:worker": "node --watch src/worker.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend install && npm --prefix frontend run build",
    "start": "node src/server.js",
    "start:worker": "node src/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema=prisma/schema.prod.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy --schema=prisma/schema.prod.prisma",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0"
  }
}
